# zappa-lite configuration
# Override these via environment variables or edit this file

# LLM Model — Qwen3-8B via OpenRouter (cheap, fast)
# For Cerebras direct (ultra-fast, near-free): cerebras/llama3.1-8b
# For better quality (slower): anthropic/claude-3.5-haiku
ZAPPA_MODEL=qwen/qwen3-8b

# OpenRouter API key (required if using OpenRouter models)
# OPENROUTER_API_KEY=sk-...

# Cerebras API key (required if using cerebras/ models)
# CEREBRAS_API_KEY=csk-...

# Max content size to process (bytes) — skip files larger than this
ZAPPA_MAX_SIZE=500000

# Never-proxy domains (comma-separated) — these bypass LLM entirely for privacy
# Defaults are built-in; add yours here
# ZAPPA_NEVER_PROXY=mybank.com,healthsite.com

# mitmproxy listen port
ZAPPA_PORT=8080